{
  "name": "backend",
  "version": "1.0.0",
  "description": "Production-grade search API for project funding platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "build": "npm run lint:check && npm run format:check && node --check src/server.js",
    "lint": "npx eslint . --ext .js,.cjs,.mjs,.ts --fix",
    "lint:check": "npx eslint . --ext .js,.cjs,.mjs,.ts",
    "format:check": "npx prettier --check . --ignore-path .prettierignore",
    "format:write": "npx prettier --write . --ignore-path .prettierignore",
    "prepare": "npm run build",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/database/init.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/syntheticAssets.unit.test.js",
    "test:integration": "jest tests/syntheticAssets.integration.test.js",
    "test:e2e": "jest tests/syntheticAssets.e2e.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/*.test.js",
    "test:integration": "jest tests/syntheticAssets.integration.test.js",
    "test:e2e": "jest tests/syntheticAssets.e2e.test.js",
    "test:synthetic": "jest tests/syntheticAssets.*.test.js",
    "test:all": "npm run test:unit && npm run test:synthetic"
  },
  "keywords": [
    "search",
    "fts",
    "fuzzy",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/exporter-jaeger": "^1.28.0",
    "@opentelemetry/exporter-prometheus": "^0.54.2",
    "@opentelemetry/exporter-zipkin": "^1.28.0",
    "@opentelemetry/instrumentation-express": "^0.42.0",
    "@opentelemetry/instrumentation-ioredis": "^0.43.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.13.2",
    "graphql-query-complexity": "^1.1.0",
    "graphql-yoga": "^5.21.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.5",
    "morgan": "^1.10.1",
    "prom-client": "^15.1.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  }
}
